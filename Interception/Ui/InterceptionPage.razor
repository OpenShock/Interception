@using OpenShock.Desktop.ModuleBase
@using OpenShock.Desktop.ModuleBase.Api
@using OpenShock.Desktop.Modules.Interception.Certificates
@using OpenShock.Desktop.Modules.Interception.HostsFile
@using OpenShock.Desktop.Modules.Interception.Server
<MudPaper Outlined="true" Class="settings-wrap">
    <!-- Title -->
    <MudText Typo="Typo.h6" Class="mb-2">PiShock API Interception</MudText>
    <MudDivider Class="mb-4"/>

    @* Server Section *@
    <MudPaper Class="pa-4 mb-4 rounded-lg" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">Server</MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
            <MudSwitch T="bool" Color="Color.Primary"
                       Value="@Service.IsRunning"
                       ValueChanged="@OnServerToggle"
                       Label="@(Service.IsRunning ? "Running" : "Stopped")"/>
            <MudChip T="string" Color="@(Service.IsRunning ? Color.Success : Color.Default)" Size="Size.Small">
                @(Service.IsRunning ? "Active" : "Inactive")
            </MudChip>
        </MudStack>
        <MudNumericField T="ushort" Label="Port" Value="@Service.Config.Port"
                         ValueChanged="@OnPortChanged" Min="1" Max="65535"
                         Disabled="@Service.IsRunning" Class="mt-2" Style="max-width: 200px;"/>
    </MudPaper>

    @* Hosts File Redirect *@
    <MudPaper Class="pa-4 mb-4 rounded-lg" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">Hosts File Redirect</MudText>
        <MudText Typo="Typo.body2" Class="mb-2">
            Redirects do.pishock.com and ps.pishock.com to 127.0.0.1 via the system hosts file.
            Each action requires administrator elevation.
        </MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudChip T="string" Color="@(HostsManager.IsEnabled ? Color.Success : Color.Default)" Size="Size.Small">
                @(HostsManager.IsEnabled ? "Active" : "Inactive")
            </MudChip>
            @if (!HostsManager.IsEnabled)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="@AddHostsEntry">
                    Add Hosts Entry
                </MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@RemoveHostsEntry">
                    Remove Hosts Entry
                </MudButton>
            }
        </MudStack>
    </MudPaper>

    @* Certificate Status *@
    <MudPaper Class="pa-4 mb-4 rounded-lg" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">Certificate</MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon
                Icon="@(CertManager.IsCaTrusted ? Icons.Material.Filled.VerifiedUser : Icons.Material.Filled.Warning)"
                Color="@(CertManager.IsCaTrusted ? Color.Success : Color.Warning)"/>
            <MudText>
                CA Certificate: @(CertManager.IsCaTrusted ? "Trusted" : "Not trusted")
            </MudText>
        </MudStack>
        @if (!CertManager.IsCaTrusted)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-2"
                       OnClick="@InstallCaCert">
                Install CA Certificate
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Class="mt-2"
                       OnClick="@RemoveCaCert">
                Remove CA Certificate
            </MudButton>
        }
    </MudPaper>

    @* Share Code Mappings *@
    <MudPaper Class="pa-4 mb-4 rounded-lg" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">Share Code Mappings</MudText>
        <MudText Typo="Typo.body2" Class="mb-2">
            Map PiShock share codes to OpenShock shockers. Each mapping can target multiple shockers
            and has configurable intensity/duration limits.
        </MudText>

        <MudTable Items="@Service.Config.ShareCodeMappings" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Share Code</MudTh>
                <MudTh>OpenShock Shockers</MudTh>
                <MudTh>Intensity</MudTh>
                <MudTh>Duration</MudTh>
                <MudTh Style="width: 100px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Key</MudTd>
                <MudTd>@GetShockerNames(context.Value)</MudTd>
                <MudTd>@context.Value.MinIntensity–@context.Value.MaxIntensity%</MudTd>
                <MudTd>@context.Value.MinDuration–@context.Value.MaxDuration s</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   Color="Color.Primary" OnClick="@(() => EditMapping(context.Key, context.Value))"/>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                   Color="Color.Error" OnClick="@(() => RemoveMapping(context.Key))"/>
                </MudTd>
            </RowTemplate>
        </MudTable>

        @* Add / Edit Mapping Form *@
        <MudPaper Class="pa-3 mt-3 rounded-lg" Outlined="true">
            <MudText Typo="Typo.subtitle1" Class="mb-2">@(_editingShareCode != null ? "Edit Mapping" : "Add Mapping")</MudText>

            <MudStack Spacing="2">
                <MudTextField T="string" Value="@_newShareCode" ValueChanged="@((string v) => _newShareCode = v)"
                              Label="Share Code" Style="max-width: 300px;"
                              Disabled="@(_editingShareCode != null)"/>

                <MudSelect T="Guid" Label="Shockers" MultiSelection="true"
                           SelectedValues="@_selectedShockerIds"
                           SelectedValuesChanged="@((IEnumerable<Guid> v) => _selectedShockerIds = v.ToHashSet())"
                           MultiSelectionTextFunc="@(ids => string.Join(", ", ids.Select(id => Guid.TryParse(id, out var g) ? GetShockerName(g) : id)))"
                           Style="max-width: 500px;">
                    @foreach (var hub in OpenShockData.Hubs.Value)
                    {
                        foreach (var shocker in hub.Shockers)
                        {
                            <MudSelectItem T="Guid" Value="@shocker.Id">@hub.Name / @shocker.Name</MudSelectItem>
                        }
                    }
                </MudSelect>

                <MudStack Row="true" Spacing="2">
                    <MudNumericField T="byte" Label="Min Intensity" Value="@_minIntensity"
                                     ValueChanged="@((byte v) => _minIntensity = v)" Min="1" Max="100"
                                     Style="max-width: 130px;"/>
                    <MudNumericField T="byte" Label="Max Intensity" Value="@_maxIntensity"
                                     ValueChanged="@((byte v) => _maxIntensity = v)" Min="1" Max="100"
                                     Style="max-width: 130px;"/>
                    <MudNumericField T="ushort" Label="Min Duration (s)" Value="@_minDuration"
                                     ValueChanged="@((ushort v) => _minDuration = v)" Min="1" Max="30"
                                     Style="max-width: 150px;"/>
                    <MudNumericField T="ushort" Label="Max Duration (s)" Value="@_maxDuration"
                                     ValueChanged="@((ushort v) => _maxDuration = v)" Min="1" Max="30"
                                     Style="max-width: 150px;"/>
                </MudStack>

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SaveMapping"
                               Disabled="@(string.IsNullOrWhiteSpace(_newShareCode) || _selectedShockerIds.Count == 0)">
                        @(_editingShareCode != null ? "Save" : "Add")
                    </MudButton>
                    @if (_editingShareCode != null)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="@CancelEdit">
                            Cancel
                        </MudButton>
                    }
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudPaper>
</MudPaper>

<style>

    .settings-wrap {
        max-width: 920px;
        margin: 0 auto;
        padding: 16px;
        border-radius: 12px;
    }

</style>

@code {
    [ModuleInject] public required InterceptionService Service { get; set; }
    [ModuleInject] public required IOpenShockData OpenShockData { get; set; }
    [ModuleInject] public required CertificateManager CertManager { get; set; }
    [ModuleInject] public required HostsFileManager HostsManager { get; set; }

    private string _newShareCode = string.Empty;
    private HashSet<Guid> _selectedShockerIds = [];
    private byte _minIntensity = 1;
    private byte _maxIntensity = 100;
    private ushort _minDuration = 1;
    private ushort _maxDuration = 15;
    private string? _editingShareCode;

    private async Task OnServerToggle(bool value)
    {
        if (value)
            await Service.StartAsync();
        else
            await Service.StopAsync();
        StateHasChanged();
    }

    private async Task OnPortChanged(ushort port)
    {
        await Service.UpdateConfig(c => c.Port = port);
    }

    private async Task AddHostsEntry()
    {
        await HostsManager.EnableAsync();
        StateHasChanged();
    }

    private async Task RemoveHostsEntry()
    {
        await HostsManager.DisableAsync();
        StateHasChanged();
    }

    private void InstallCaCert()
    {
        CertManager.InstallCaCertificate();
        StateHasChanged();
    }

    private void RemoveCaCert()
    {
        CertManager.RemoveCaCertificate();
        StateHasChanged();
    }

    private void EditMapping(string shareCode, ShareCodeMapping mapping)
    {
        _editingShareCode = shareCode;
        _newShareCode = shareCode;
        _selectedShockerIds = [.. mapping.ShockerIds];
        _minIntensity = mapping.MinIntensity;
        _maxIntensity = mapping.MaxIntensity;
        _minDuration = mapping.MinDuration;
        _maxDuration = mapping.MaxDuration;
        StateHasChanged();
    }

    private void CancelEdit()
    {
        ResetForm();
        StateHasChanged();
    }

    private async Task SaveMapping()
    {
        if (string.IsNullOrWhiteSpace(_newShareCode) || _selectedShockerIds.Count == 0) return;

        var mapping = new ShareCodeMapping
        {
            ShockerIds = _selectedShockerIds.ToList(),
            MinIntensity = _minIntensity,
            MaxIntensity = _maxIntensity,
            MinDuration = _minDuration,
            MaxDuration = _maxDuration
        };

        await Service.UpdateConfig(c => c.ShareCodeMappings[_newShareCode] = mapping);
        ResetForm();
        StateHasChanged();
    }

    private async Task RemoveMapping(string code)
    {
        await Service.UpdateConfig(c => c.ShareCodeMappings.Remove(code));
        if (_editingShareCode == code) ResetForm();
        StateHasChanged();
    }

    private void ResetForm()
    {
        _editingShareCode = null;
        _newShareCode = string.Empty;
        _selectedShockerIds = [];
        _minIntensity = 1;
        _maxIntensity = 100;
        _minDuration = 1;
        _maxDuration = 15;
    }

    private string GetShockerNames(ShareCodeMapping mapping)
    {
        if (mapping.ShockerIds.Count == 0) return "(none)";
        return string.Join(", ", mapping.ShockerIds.Select(GetShockerName));
    }

    private string GetShockerName(Guid shockerId)
    {
        foreach (var hub in OpenShockData.Hubs.Value)
        {
            foreach (var shocker in hub.Shockers)
            {
                if (shocker.Id == shockerId)
                    return $"{hub.Name} / {shocker.Name}";
            }
        }

        return shockerId.ToString();
    }

}
